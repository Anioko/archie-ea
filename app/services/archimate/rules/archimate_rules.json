  "cardinality_rules": {
    "Capability": {
      "outbound": {
        "min": 1,
        "types": ["Realization", "Aggregation", "Serving"],
        "severity": "warning",
        "message": "Capability must realize or aggregate downstream behavior"
      },
      "inbound": {
        "min": 1,
        "types": ["Aggregation", "Serving"],
        "severity": "warning",
        "message": "Capability should be aggregated by value streams or referenced by strategy elements"
      }
    },
    "BusinessProcess": {
      "outbound": {
        "min": 1,
        "types": ["Realization", "Flow", "Triggering", "Access"],
        "severity": "warning",
        "message": "BusinessProcess should connect to services, data, or events"
      },
      "inbound": {
        "min": 1,
        "types": ["Assignment", "Triggering", "Flow", "Serving"],
        "severity": "warning",
        "message": "BusinessProcess should be triggered or assigned from business actors/roles"
      }
    },
    "Requirement": {
      "outbound": {
        "min": 1,
        "types": ["Realization", "Influence", "Serving", "Specialization"],
        "severity": "warning",
        "message": "Requirement needs realization or influence relationship"
      },
      "inbound": {
        "min": 1,
        "types": ["Influence", "Realization", "Specialization"],
        "severity": "warning",
        "message": "Requirement should trace back to goals, principles, or higher-level requirements"
      }
    },
    "Goal": {
      "outbound": {
        "min": 1,
        "types": ["Realization", "Aggregation", "Influence"],
        "severity": "warning",
        "message": "Goal should decompose or realize outcomes/requirements"
      },
      "inbound": {
        "min": 1,
        "types": ["Influence", "Realization", "Aggregation"],
        "severity": "warning",
        "message": "Goal should be influenced or realized by drivers, outcomes, or capabilities"
      }
    },
    "ApplicationComponent": {
      "outbound": {
        "min": 1,
        "types": ["Serving", "Realization", "Assignment", "Composition"],
        "severity": "warning",
        "message": "ApplicationComponent must expose services or contain structure"
      },
      "inbound": {
        "min": 1,
        "types": ["Assignment", "Serving", "Realization", "Aggregation"],
        "severity": "warning",
        "message": "ApplicationComponent should be realized or used by technology or business elements"
      }
    },
    "TechnologyService": {
      "outbound": {
        "min": 1,
        "types": ["Serving", "Realization", "Aggregation"],
        "severity": "warning",
        "message": "TechnologyService should support application or lower layers"
      },
      "inbound": {
        "min": 1,
        "types": ["Realization", "Assignment", "Serving"],
        "severity": "warning",
        "message": "TechnologyService should be realized by technology functions/components"
      }
    },
    "DataObject": {
      "outbound": {
        "min": 1,
        "types": ["Realization", "Specialization"],
        "severity": "warning",
        "message": "DataObject should realize or specialize business objects"
      },
      "inbound": {
        "min": 1,
        "types": ["Access", "Composition", "Aggregation"],
        "severity": "info",
        "message": "DataObject should be accessed or structured by application behavior"
      }
    }
  }
}
