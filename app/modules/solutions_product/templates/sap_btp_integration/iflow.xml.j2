{# sap_btp_integration/iflow.xml.j2 — SAP BTP Integration Suite iFlow descriptor.
   Context: solution_id, bundle_id, solution_name, sol_snake, sol_kebab,
            source_system, target_system, source_entity,
            field_mappings (list of {source, target}),
            error_handling (default 'StoreAndForward') #}
<?xml version="1.0" encoding="UTF-8"?>
<!-- GENERATED BY ARCHIE — solution_id: {{ solution_id }}, bundle_id: {{ bundle_id }} -->
<!-- DO NOT EDIT IN PLACE — REGENERATE FROM ARCHITECTURE -->
<!--
  iFlow: {{ solution_name }}
  Source: {{ source_system }} ({{ source_entity }})
  Target: {{ target_system }}
  Error Handling: {{ error_handling | default('StoreAndForward') }}
-->
<bpmn2:definitions
  xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  id="{{ sol_snake }}_iflow"
  targetNamespace="{{ sol_kebab }}">

  <bpmn2:collaboration id="Collaboration_{{ sol_snake }}">
    <bpmn2:participant id="Sender_{{ sol_snake }}" name="{{ source_system }}">
      <bpmn2:extensionElements>
        <ifl:property>
          <ifl:key>componentVersion</ifl:key>
          <ifl:value>1.0.0</ifl:value>
        </ifl:property>
        <ifl:property>
          <ifl:key>address</ifl:key>
          <ifl:value>/sap/opu/odata/sap/{{ source_entity }}Set</ifl:value>
        </ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:participant>

    <bpmn2:participant id="Receiver_{{ sol_snake }}" name="{{ target_system }}">
      <bpmn2:extensionElements>
        <ifl:property>
          <ifl:key>componentVersion</ifl:key>
          <ifl:value>1.0.0</ifl:value>
        </ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:participant>

    <bpmn2:messageFlow
      id="MessageFlow_In"
      sourceRef="Sender_{{ sol_snake }}"
      targetRef="IntegrationProcess_{{ sol_snake }}" />

    <bpmn2:messageFlow
      id="MessageFlow_Out"
      sourceRef="IntegrationProcess_{{ sol_snake }}"
      targetRef="Receiver_{{ sol_snake }}" />
  </bpmn2:collaboration>

  <bpmn2:process id="IntegrationProcess_{{ sol_snake }}" name="{{ solution_name }}">

    <bpmn2:startEvent id="StartEvent_{{ sol_snake }}" name="Receive {{ source_entity }}">
      <bpmn2:extensionElements>
        <ifl:property>
          <ifl:key>ComponentType</ifl:key>
          <ifl:value>StartEvent</ifl:value>
        </ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:startEvent>

    <!-- Step 1: Fetch OData from source system -->
    <bpmn2:callActivity
      id="Request_{{ source_entity }}"
      name="GET {{ source_entity }}Set">
      <bpmn2:extensionElements>
        <ifl:property>
          <ifl:key>ComponentType</ifl:key>
          <ifl:value>RequestReply</ifl:value>
        </ifl:property>
        <ifl:property>
          <ifl:key>httpMethod</ifl:key>
          <ifl:value>GET</ifl:value>
        </ifl:property>
        <ifl:property>
          <ifl:key>requestPath</ifl:key>
          <ifl:value>/sap/opu/odata/sap/{{ source_entity }}Set?$format=json&amp;$top=1000</ifl:value>
        </ifl:property>
        <ifl:property>
          <ifl:key>authType</ifl:key>
          <ifl:value>BasicAuthentication</ifl:value>
        </ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:callActivity>

    <!-- Step 2: Map fields ({{ source_entity }} → target) -->
    <bpmn2:callActivity
      id="MessageMapping_{{ sol_snake }}"
      name="Map {{ source_entity }} to {{ target_system }}">
      <bpmn2:extensionElements>
        <ifl:property>
          <ifl:key>ComponentType</ifl:key>
          <ifl:value>MessageMapping</ifl:value>
        </ifl:property>
        <!-- Field Mappings:
{% for m in field_mappings %}
             {{ m.source }} → {{ m.target }}
{% endfor %}
        -->
      </bpmn2:extensionElements>
    </bpmn2:callActivity>

    <!-- Step 3: Error handling -->
    <bpmn2:callActivity
      id="ErrorHandler_{{ sol_snake }}"
      name="{{ error_handling | default('StoreAndForward') }}">
      <bpmn2:extensionElements>
        <ifl:property>
          <ifl:key>ComponentType</ifl:key>
          <ifl:value>ErrorConfiguration</ifl:value>
        </ifl:property>
        <ifl:property>
          <ifl:key>errorHandling</ifl:key>
          <ifl:value>{{ error_handling | default('StoreAndForward') }}</ifl:value>
        </ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:callActivity>

    <!-- Step 4: Send to target -->
    <bpmn2:callActivity
      id="Send_{{ sol_snake }}"
      name="Send to {{ target_system }}">
      <bpmn2:extensionElements>
        <ifl:property>
          <ifl:key>ComponentType</ifl:key>
          <ifl:value>Send</ifl:value>
        </ifl:property>
        <ifl:property>
          <ifl:key>httpMethod</ifl:key>
          <ifl:value>POST</ifl:value>
        </ifl:property>
        <ifl:property>
          <ifl:key>authType</ifl:key>
          <ifl:value>OAuth2ClientCredentials</ifl:value>
        </ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:callActivity>

    <bpmn2:endEvent id="EndEvent_{{ sol_snake }}" name="Integration Complete">
      <bpmn2:extensionElements>
        <ifl:property>
          <ifl:key>ComponentType</ifl:key>
          <ifl:value>EndEvent</ifl:value>
        </ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:endEvent>

    <!-- Sequence flows -->
    <bpmn2:sequenceFlow id="Flow1" sourceRef="StartEvent_{{ sol_snake }}"        targetRef="Request_{{ source_entity }}" />
    <bpmn2:sequenceFlow id="Flow2" sourceRef="Request_{{ source_entity }}"        targetRef="MessageMapping_{{ sol_snake }}" />
    <bpmn2:sequenceFlow id="Flow3" sourceRef="MessageMapping_{{ sol_snake }}"     targetRef="ErrorHandler_{{ sol_snake }}" />
    <bpmn2:sequenceFlow id="Flow4" sourceRef="ErrorHandler_{{ sol_snake }}"       targetRef="Send_{{ sol_snake }}" />
    <bpmn2:sequenceFlow id="Flow5" sourceRef="Send_{{ sol_snake }}"               targetRef="EndEvent_{{ sol_snake }}" />

  </bpmn2:process>

</bpmn2:definitions>
