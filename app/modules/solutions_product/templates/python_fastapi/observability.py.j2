def start_metrics_server(port: int = 9090) -> None:
    """Start the Prometheus metrics HTTP server.

    Typically called once at app startup. Set METRICS_PORT env var to override.
    """
    if not _METRICS_ENABLED:
        logger.warning("Cannot start metrics server — prometheus_client not installed")
        return
    actual_port = int(os.environ.get("METRICS_PORT", port))
    start_http_server(actual_port)
    logger.info("Prometheus metrics server started on :%d", actual_port)


