# ── Retry decorator ───────────────────────────────────────────────────────────

def retry(
    max_retries: int = 3,
    backoff: str = "exponential",
    base_delay_ms: int = 100,
    max_delay_ms: int = 5000,
    exceptions: tuple = (Exception,),
):
    """Retry decorator with configurable backoff.

    Args:
        max_retries: maximum number of retry attempts
        backoff: "exponential" | "linear" | "constant"
        base_delay_ms: initial delay in milliseconds
        max_delay_ms: maximum delay cap in milliseconds
        exceptions: tuple of exception types to catch and retry
    """
    def decorator(func: Callable) -> Callable:
        @wraps(func)
        async def async_wrapper(*args: Any, **kwargs: Any) -> Any:
            last_exc: Optional[Exception] = None
            for attempt in range(max_retries + 1):
                try:
                    return await func(*args, **kwargs)
                except exceptions as exc:
                    last_exc = exc
                    if attempt == max_retries:
                        break
                    delay = _compute_delay(attempt, backoff, base_delay_ms, max_delay_ms)
                    logger.warning(
                        "%s attempt %d/%d failed: %s — retrying in %.1fs",
                        func.__name__, attempt + 1, max_retries, exc, delay / 1000,
                    )
                    await asyncio.sleep(delay / 1000)
            raise last_exc  # type: ignore[misc]

        @wraps(func)
        def sync_wrapper(*args: Any, **kwargs: Any) -> Any:
            import time as _time
            last_exc = None
            for attempt in range(max_retries + 1):
                try:
                    return func(*args, **kwargs)
                except exceptions as exc:
                    last_exc = exc
                    if attempt == max_retries:
                        break
                    delay = _compute_delay(attempt, backoff, base_delay_ms, max_delay_ms)
                    _time.sleep(delay / 1000)
            raise last_exc  # type: ignore[misc]

        return async_wrapper if asyncio.iscoroutinefunction(func) else sync_wrapper
    return decorator


def _compute_delay(attempt: int, backoff: str, base_ms: int, max_ms: int) -> float:
    if backoff == "exponential":
        return min(base_ms * (2 ** attempt), max_ms)
    if backoff == "linear":
        return min(base_ms * (attempt + 1), max_ms)
    return base_ms  # constant


