# ── Customer Portal ──────────────────────────────────────────────────────────

@router.post("/portal")
async def create_portal_session(body: PortalRequest, request: Request):
    """Redirect an existing customer to the Stripe Customer Portal."""
    customer_id = getattr(request.state, "stripe_customer_id", None)
    if not customer_id:
        raise HTTPException(status_code=400, detail="No Stripe customer linked to this account")
    try:
        session = stripe.billing_portal.Session.create(
            customer=customer_id,
            return_url=body.return_url or f"{FRONTEND_URL}/billing",
        )
        return {"portal_url": session.url}
    except stripe.StripeError as e:
        logger.error("Stripe portal error: %s", e)
        raise HTTPException(status_code=400, detail=str(e))


