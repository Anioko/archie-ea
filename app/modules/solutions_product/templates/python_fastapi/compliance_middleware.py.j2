# Controls: right to erasure, PII masking, consent tracking

# Fields that contain PII — mask in logs and never include in audit exports
_PII_FIELDS = {
    "email", "phone", "mobile", "address", "postcode", "zip_code",
    "national_id", "passport", "date_of_birth", "full_name", "first_name",
    "last_name", "ip_address", "device_id",
