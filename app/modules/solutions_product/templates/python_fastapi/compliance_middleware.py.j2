# Controls: tokenisation stubs, no card data in logs, TLS 1.2 enforcement

_CARD_PATTERN = re.compile(r"\b(?:\d[ -]?){13,19}\b")
_CVV_PATTERN = re.compile(r"\b\d{3,4}\b")

_CARD_FIELDS = {"card_number", "pan", "cvv", "cvv2", "cvc", "expiry", "card_expiry"}


def tokenise_card(card_number: str) -> str:
    """Return a PCI-safe token — NEVER store raw card numbers."""
    import hashlib
    return "TOK_" + hashlib.sha256(card_number.encode()).hexdigest()[:16].upper()


def scrub_card_data(text: str) -> str:
    """Remove card numbers from log strings (PCI req 3.4)."""
    text = _CARD_PATTERN.sub("[CARD_REDACTED]", text)
    return text


class PCIDSSLogFilter(logging.Filter):
    """Strip card numbers from all log records (PCI DSS req 3.4)."""

    def filter(self, record: logging.LogRecord) -> bool:
        record.msg = scrub_card_data(str(record.msg))
        return True
