{% if compliance.sox %}
# ── SOX Compliance ────────────────────────────────────────────────────────────
# Controls: immutable audit log, 7-year retention, segregation of duties

_SOX_RETENTION_YEARS = 7


class SOXAuditMiddleware(BaseHTTPMiddleware):
    """Emit an immutable audit log entry for every state-changing request.

    Logs: timestamp, user_id, method, path, status_code, request_id.
    Audit records must never be deleted (7-year retention enforced at DB level).
    """

    async def dispatch(self, request: Request, call_next: Callable) -> Response:
        request_id = str(uuid.uuid4())
        start = time.time()
        response = await call_next(request)
        elapsed_ms = round((time.time() - start) * 1000, 1)

        if request.method in ("POST", "PUT", "PATCH", "DELETE"):
            user_id = getattr(getattr(request, "state", None), "user_id", "anonymous")
            logger.info(
                "SOX_AUDIT request_id=%s user=%s %s %s status=%d elapsed_ms=%s",
                request_id, user_id, request.method, request.url.path,
                response.status_code, elapsed_ms,
            )
        response.headers["X-Request-Id"] = request_id
        return response
{% endif %}

