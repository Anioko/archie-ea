def mask_pii(data: dict) -> dict:
    """Return a copy of data with PII fields masked for logging."""
    return {
        k: ("***MASKED***" if k.lower() in _PII_FIELDS else v)
        for k, v in data.items()
    }


class GDPRConsentMiddleware(BaseHTTPMiddleware):
    """Enforce consent header on data-write endpoints.

    POST/PUT/PATCH requests to /api/* must include X-Data-Consent: true
    to confirm the user has given consent for data processing.
    """

    async def dispatch(self, request: Request, call_next: Callable) -> Response:
        if request.method in ("POST", "PUT", "PATCH") and request.url.path.startswith("/api/"):
            consent = request.headers.get("X-Data-Consent", "").lower()
            if consent != "true":
                from starlette.responses import JSONResponse
                return JSONResponse(
                    {"detail": "GDPR consent header X-Data-Consent: true is required"},
                    status_code=451,  # 451 Unavailable For Legal Reasons
                )
        return await call_next(request)
