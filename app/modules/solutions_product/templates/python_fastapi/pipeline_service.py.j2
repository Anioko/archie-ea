@router.get("/{job_id}/status", response_model=PipelineStatus)
async def get_status(
    job_id: str,
    user: TokenPayload = Depends(verify_token),
):
    """Get processing status for a pipeline job."""
    if job_id in _job_results:
        return PipelineStatus(id=job_id, status="completed", progress_pct=100.0)
    return PipelineStatus(id=job_id, status="pending")


@router.get("/{job_id}/result", response_model=PipelineResult)
async def get_result(
    job_id: str,
    user: TokenPayload = Depends(verify_token),
):
    """Get processing result for a completed pipeline job."""
    if job_id in _job_results:
        return _job_results[job_id]
    return PipelineResult(id=job_id)
