@router.post("/upload", response_model=PipelineResult)
async def upload_and_process(
    file: UploadFile = File(...),
    user: TokenPayload = Depends(verify_token),
):
    """Upload a document and process through the {{ module.get('display_name', module_key) }} pipeline."""
    import uuid as _uuid
    job_id = str(_uuid.uuid4())
    contents = await file.read()
    result = await _pipeline.process(contents, filename=file.filename)
    pr = PipelineResult(
        id=job_id,
        data=result.get("output", result),
        quality_metrics={},
        processing_time_seconds=result.get("processing_time_seconds", 0),
    )
    _job_results[job_id] = pr
    return pr
