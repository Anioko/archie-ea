# GENERATED BY ARCHIE
# solution_id: {{ solution_id }}
# bundle_id: {{ bundle_id }}
[project]
name = "archie-product-{{ solution_id }}"
version = "1.0.0"
description = "Generated from A.R.C.H.I.E. solution: {{ solution_name }}"
requires-python = ">=3.11"
dependencies = [
    "fastapi>=0.115",
    "uvicorn[standard]>=0.32",
    "sqlalchemy[asyncio]>=2.0",
    "asyncpg>=0.30",
    "pydantic>=2.0",
    "pydantic-settings>=2.0",
    "python-dotenv>=1.0",
    "python-jose[cryptography]>=3.3",
    "passlib[bcrypt]>=1.7",
    "python-multipart>=0.0.9",
    "httpx>=0.27",
    "alembic>=1.13",
{% if workers %}
    "celery[redis]>=5.4",
    "redis>=5.0",
{% endif %}
{% if payment_config and payment_config.provider == "stripe" %}
    "stripe>=10.0",
{% endif %}
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
    "pytest-asyncio>=0.24",
    "httpx>=0.27",
    "ruff>=0.5",
]

[tool.pytest.ini_options]
asyncio_mode = "auto"
