#!/bin/sh
# GENERATED BY ARCHIE — Entrypoint script
set -e
echo "Starting {{ solution_name | default('application') }}..."

# Run database migrations
echo "Running migrations..."
alembic upgrade head || true

# Seed demo data on first boot (skip if SEED_ON_BOOT=false)
if [ "${SEED_ON_BOOT:-true}" = "true" ]; then
    if [ ! -f /tmp/.seeded ]; then
        echo "Seeding demo data..."
        python seed.py --count 10 && touch /tmp/.seeded || echo "Seed skipped (non-fatal)"
    fi
fi

exec uvicorn app.main:app --host 0.0.0.0 --port 8000
