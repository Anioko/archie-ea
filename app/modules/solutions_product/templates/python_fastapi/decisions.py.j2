def {{ dm.name }}({% for inp in dm.inputs %}{{ inp }}: Any{% if not loop.last %}, {% endif %}{% endfor %}) -> Optional[dict]:
    """{{ dm.description }}

    Hit policy: UNIQUE — raises ValueError if more than one row matches.
    Returns None if no rows match.
    """
    inputs = { {% for inp in dm.inputs %}"{{ inp }}": {{ inp }}{% if not loop.last %}, {% endif %}{% endfor %} }
    matches = [
        outputs.copy()
        for conditions, outputs in _{{ dm.name | upper }}_TABLE
        if _match_{{ dm.name }}_row(conditions, inputs)
    ]
    if len(matches) > 1:
        raise ValueError(
            f"Decision '{{ dm.name }}' hit policy UNIQUE violated: "
            f"{len(matches)} rows matched inputs={inputs}"
        )
    return matches[0] if matches else None

{% elif dm.hit_policy == "ANY" %}
def {{ dm.name }}({% for inp in dm.inputs %}{{ inp }}: Any{% if not loop.last %}, {% endif %}{% endfor %}) -> Optional[dict]:
    """{{ dm.description }}

    Hit policy: ANY — all matching rows must produce identical outputs.
    Raises ValueError if outputs conflict.
    Returns None if no rows match.
    """
    inputs = { {% for inp in dm.inputs %}"{{ inp }}": {{ inp }}{% if not loop.last %}, {% endif %}{% endfor %} }
    matches = [
        outputs.copy()
        for conditions, outputs in _{{ dm.name | upper }}_TABLE
        if _match_{{ dm.name }}_row(conditions, inputs)
    ]
    if not matches:
        return None
    first = matches[0]
    for m in matches[1:]:
        if m != first:
            raise ValueError(
                f"Decision '{{ dm.name }}' hit policy ANY violated: "
                f"conflicting outputs {first} vs {m} for inputs={inputs}"
            )
    return first

