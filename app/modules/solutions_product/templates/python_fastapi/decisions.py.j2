def _match_{{ dm.name }}_row(conditions: dict, inputs: dict) -> bool:
    """Return True if all conditions match the provided inputs."""
    for key, expected in conditions.items():
        actual = inputs.get(key)
        if actual is None:
            return False
        if isinstance(expected, str):
            if expected.startswith(">="):
                try:
                    if not (float(str(actual)) >= float(expected[2:])):
                        return False
                except (TypeError, ValueError):
                    return False
            elif expected.startswith(">"):
                try:
                    if not (float(str(actual)) > float(expected[1:])):
                        return False
                except (TypeError, ValueError):
                    return False
            elif expected.startswith("<="):
                try:
                    if not (float(str(actual)) <= float(expected[2:])):
                        return False
                except (TypeError, ValueError):
                    return False
            elif expected.startswith("<"):
                try:
                    if not (float(str(actual)) < float(expected[1:])):
                        return False
                except (TypeError, ValueError):
                    return False
            elif expected.startswith("!="):
                if str(actual) == expected[2:].strip():
                    return False
            elif expected.startswith("[") and ".." in expected:
                # Range: [low..high]
                try:
                    parts = expected.strip("[]").split("..")
                    low, high = float(parts[0]), float(parts[1])
                    if not (low <= float(str(actual)) <= high):
                        return False
                except (TypeError, ValueError, IndexError):
                    return False
            elif expected == "*":
                pass  # wildcard — always matches
            elif str(actual) != str(expected):
                return False
        elif isinstance(expected, list):
            if actual not in expected:
                return False
        elif actual != expected:
            return False
    return True


