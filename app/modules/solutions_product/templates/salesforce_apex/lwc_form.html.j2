{# salesforce_apex/lwc_form.html.j2 #}
{# Generates Lightning Web Component HTML for a create/edit record form. #}
{# Context: solution_id, bundle_id, model_name, model_label, fields, component_name #}
<!-- GENERATED BY ARCHIE — solution_id: {{ solution_id }}, bundle_id: {{ bundle_id }} -->
<!-- DO NOT EDIT IN PLACE — REGENERATE FROM ARCHITECTURE -->
<template>
    <c-toast-container></c-toast-container>

    <template lwc:if={isLoading}>
        <lightning-spinner alternative-text="Saving" size="medium"></lightning-spinner>
    </template>

    <lightning-card title={cardTitle} icon-name="standard:record_create">
        <div class="slds-p-around_medium">
            <lightning-record-edit-form
                record-id={recordId}
                object-api-name={objectApiName}
                onsuccess={handleSuccess}
                onerror={handleError}>

                <lightning-messages></lightning-messages>

                {% for field in fields %}
                <lightning-input-field
                    field-name="{{ field.api_name }}"{% if field.required %} required{% endif %}>
                </lightning-input-field>
                {% endfor %}

                <div slot="footer" class="slds-m-top_medium slds-grid slds-grid_align-end">
                    <lightning-button
                        label="Cancel"
                        onclick={handleCancel}
                        class="slds-m-right_x-small">
                    </lightning-button>
                    <lightning-button
                        variant="brand"
                        type="submit"
                        label={saveLabel}
                        onclick={handleSubmit}>
                    </lightning-button>
                </div>
            </lightning-record-edit-form>
        </div>
    </lightning-card>
</template>
