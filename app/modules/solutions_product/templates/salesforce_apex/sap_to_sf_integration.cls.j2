    // ── Salesforce upsert ──────────────────────────────────────────────────

    @TestVisible
    private static Integer upsertRecords(List<{{ target_object }}> records) {
        if (records.isEmpty()) {
            return 0;
        }
        if (!Schema.sObjectType.{{ target_object }}.isCreateable() &&
            !Schema.sObjectType.{{ target_object }}.isUpdateable()) {
            throw new SapIntegrationException('Insufficient permissions to upsert {{ target_object }} records');
        }
        SObjectAccessDecision decision = Security.stripInaccessible(
            AccessType.UPSERTABLE,
            records
        );
        List<SObject> sanitizedRecords = decision.getRecords();
        Database.UpsertResult[] results =
            Database.upsert(sanitizedRecords, false);

        Integer successCount = 0;
        List<String> errors = new List<String>();
        for (Database.UpsertResult r : results) {
            if (r.isSuccess()) {
                successCount++;
            } else {
                for (Database.Error err : r.getErrors()) {
                    errors.add(err.getStatusCode() + ': ' + err.getMessage());
                }
            }
        }
        if (!errors.isEmpty()) {
            throw new SapIntegrationException('SAP sync upsert failed: ' + String.join(errors, '; '));
        }
        return successCount;
    }

    @TestVisible
    private static Integer normalizeTop(Integer top) {
        Integer candidate = (top == null || top <= 0) ? DEFAULT_TOP : top;
        return Math.min(candidate, MAX_TOP);
    }

    @TestVisible
    private static Integer normalizeSkip(Integer skip) {
        Integer candidate = (skip == null || skip < 0) ? 0 : skip;
        return Math.min(candidate, MAX_SKIP);
    }

    @TestVisible
    private static String buildEndpoint(Integer top, Integer skip) {
        return SAP_SERVICE_ROOT +
            '/{{ source_entity }}Set' +
            '?$format=json' +
            '&$top=' + String.valueOf(top) +
            '&$skip=' + String.valueOf(skip);
    }

    @TestVisible
    private static String sanitizeMessage(String raw) {
        if (String.isBlank(raw)) {
            return '';
        }
        return raw.abbreviate(500).replace('\n', ' ').replace('\r', ' ');
    }

