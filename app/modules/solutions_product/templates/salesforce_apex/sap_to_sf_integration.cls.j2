    // ── SAP OData fetch ────────────────────────────────────────────────────

    @TestVisible
    private static List<Map<String, Object>> fetchFromSAP(Integer top, Integer skip) {
        Integer boundedTop = normalizeTop(top);
        Integer boundedSkip = normalizeSkip(skip);
        String endpoint = buildEndpoint(boundedTop, boundedSkip);

        HttpRequest req = new HttpRequest();
        req.setEndpoint(endpoint);
        req.setMethod('GET');
        req.setHeader('Accept', 'application/json');
        req.setTimeout(30000);

        Http http = new Http();
        HttpResponse res = http.send(req);

        if (res.getStatusCode() != HTTP_OK) {
            throw new SapIntegrationException(
                'SAP OData call failed. Status: ' + res.getStatusCode() +
                ' Body: ' + sanitizeMessage(res.getBody())
            );
        }

        Object deserialized = JSON.deserializeUntyped(res.getBody());
        if (!(deserialized instanceof Map<String, Object>)) {
            throw new SapIntegrationException('SAP payload root was not an object.');
        }
        Map<String, Object> envelope = (Map<String, Object>) deserialized;
        Object dNode = envelope.get('d');
        if (!(dNode instanceof Map<String, Object>)) {
            throw new SapIntegrationException('SAP payload did not contain a d envelope.');
        }
        Map<String, Object> d = (Map<String, Object>) dNode;
        Object resultsNode = d.get('results');
        if (!(resultsNode instanceof List<Object>)) {
            throw new SapIntegrationException('SAP payload did not contain a results array.');
        }
        List<Object> results = (List<Object>) resultsNode;

        List<Map<String, Object>> records = new List<Map<String, Object>>();
        for (Object item : results) {
            if (!(item instanceof Map<String, Object>)) {
                throw new SapIntegrationException('SAP results entry was not an object.');
            }
            records.add((Map<String, Object>) item);
        }
        return records;
    }

