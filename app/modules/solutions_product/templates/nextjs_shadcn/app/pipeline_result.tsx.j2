{# Pipeline Result Page — SFG screen for editable_data_table pattern #}
// GENERATED BY ARCHIE (Screen Flow Graph)
// solution_id: {{ solution_id }}
// screen_pattern: editable_data_table + detail_view_with_actions
"use client";

import { useEffect, useState } from "react";
import { useParams } from "next/navigation";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/ui/table";
import { Input } from "@/components/ui/input";
import { CheckCircle, Edit2, Save, X, Download, Clock } from "lucide-react";

const _BASE_PATH = process.env.NEXT_PUBLIC_BASE_PATH ?? "{{ base_path }}";

interface PipelineResult {
  id: string;
  status: string;
  data: {
    items?: Array<Record<string, unknown>>;
    output?: Record<string, unknown>;
    steps_completed?: string[];
  };
  quality_metrics: Record<string, number>;
  processing_time_seconds: number;
}

export default function PipelineResultPage() {
  const params = useParams();
  const [result, setResult] = useState<PipelineResult | null>(null);
  const [editingRow, setEditingRow] = useState<number | null>(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const token = typeof window !== "undefined" ? localStorage.getItem("token") : null;
    const headers: Record<string, string> = {};
    if (token) headers["Authorization"] = `Bearer ${token}`;

    fetch(`${_BASE_PATH}/api/{{ module_key }}/${params.id}/result`, {
      headers,
    })
      .then(r => r.json())
      .then(data => { setResult(data); setLoading(false); })
      .catch(() => setLoading(false));
  }, [params.id]);

  if (loading) {
    return <div className="container mx-auto py-8 text-center">Loading...</div>;
  }

  if (!result) {
    return <div className="container mx-auto py-8 text-center">Result not found</div>;
  }

  const items = result.data?.items || [];
  const columns = items.length > 0 ? Object.keys(items[0]) : [];

  return (
    <div className="container mx-auto py-8 space-y-6">
      {/* Status Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold">Processing Result</h1>
          <p className="text-muted-foreground flex items-center gap-2 mt-1">
            <Clock className="h-4 w-4" />
            Processed in {result.processing_time_seconds.toFixed(1)}s
          </p>
        </div>
        <div className="flex items-center gap-2">
          <Badge variant={result.status === "completed" ? "default" : "destructive"}>
            {result.status}
          </Badge>
          <Button variant="outline" size="sm">
            <Download className="h-4 w-4 mr-1" /> Export
          </Button>
        </div>
      </div>

      {/* Quality Metrics */}
      {Object.keys(result.quality_metrics).length > 0 && (
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
          {Object.entries(result.quality_metrics).map(([key, value]) => (
            <Card key={key}>
              <CardContent className="pt-4 text-center">
                <p className="text-2xl font-bold">{typeof value === "number" ? `${(value * 100).toFixed(1)}%` : value}</p>
                <p className="text-sm text-muted-foreground">{key.replace(/_/g, " ")}</p>
              </CardContent>
            </Card>
          ))}
        </div>
      )}

      {/* Pipeline Steps Completed */}
      {result.data?.steps_completed && (
        <Card>
          <CardHeader>
            <CardTitle className="text-sm">Pipeline Steps</CardTitle>
          </CardHeader>
          <CardContent>
            <div className="flex flex-wrap gap-2">
              {result.data.steps_completed.map((step, i) => (
                <Badge key={i} variant="outline" className="flex items-center gap-1">
                  <CheckCircle className="h-3 w-3 text-green-500" />
                  {step.replace(/_/g, " ")}
                </Badge>
              ))}
            </div>
          </CardContent>
        </Card>
      )}

      {/* Extracted Data Table */}
      {items.length > 0 && (
        <Card>
          <CardHeader>
            <CardTitle>Extracted Data ({items.length} items)</CardTitle>
            <CardDescription>Review and edit extracted data before submitting</CardDescription>
          </CardHeader>
          <CardContent>
            <Table>
              <TableHeader>
                <TableRow>
                  {columns.map(col => (
                    <TableHead key={col}>{col.replace(/_/g, " ")}</TableHead>
                  ))}
                  <TableHead className="w-20">Actions</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {items.map((item, rowIdx) => (
                  <TableRow key={rowIdx}>
                    {columns.map(col => (
                      <TableCell key={col}>
                        {editingRow === rowIdx ? (
                          <Input
                            defaultValue={String(item[col] ?? "")}
                            className="h-8"
                          />
                        ) : (
                          String(item[col] ?? "")
                        )}
                      </TableCell>
                    ))}
                    <TableCell>
                      {editingRow === rowIdx ? (
                        <div className="flex gap-1">
                          <Button size="icon" variant="ghost" className="h-8 w-8" onClick={() => setEditingRow(null)}>
                            <Save className="h-4 w-4" />
                          </Button>
                          <Button size="icon" variant="ghost" className="h-8 w-8" onClick={() => setEditingRow(null)}>
                            <X className="h-4 w-4" />
                          </Button>
                        </div>
                      ) : (
                        <Button size="icon" variant="ghost" className="h-8 w-8" onClick={() => setEditingRow(rowIdx)}>
                          <Edit2 className="h-4 w-4" />
                        </Button>
                      )}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
        </Card>
      )}

      {/* Submit Actions */}
      <div className="flex justify-end gap-2">
        <Button variant="outline">Save as Draft</Button>
        <Button>
          <CheckCircle className="h-4 w-4 mr-2" />
          Approve and Submit
        </Button>
      </div>
    </div>
  );
}
