{# Pipeline Upload Page — SFG screen for file_upload_with_progress pattern #}
// GENERATED BY ARCHIE (Screen Flow Graph)
// solution_id: {{ solution_id }}
// screen_pattern: file_upload_with_progress
"use client";

import { useState, useCallback } from "react";
import { useRouter } from "next/navigation";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Progress } from "@/components/ui/progress";
import { Badge } from "@/components/ui/badge";
import { Upload, FileText, CheckCircle, AlertCircle, Loader2, Download } from "lucide-react";

// Use the baked-in base path so API calls route through nginx → Next.js rewrites → FastAPI
const _BASE_PATH = process.env.NEXT_PUBLIC_BASE_PATH ?? "{{ base_path }}";

type ProcessingStatus = "idle" | "uploading" | "processing" | "completed" | "error";

interface ProcessingResult {
  id: string;
  status: string;
  data: Record<string, unknown>;
  quality_metrics?: Record<string, number>;
  processing_time_seconds: number;
}

export default function PipelineUploadPage() {
  const router = useRouter();
  const [file, setFile] = useState<File | null>(null);
  const [status, setStatus] = useState<ProcessingStatus>("idle");
  const [progress, setProgress] = useState(0);
  const [result, setResult] = useState<ProcessingResult | null>(null);
  const [error, setError] = useState<string | null>(null);

  const handleDrop = useCallback((e: React.DragEvent) => {
    e.preventDefault();
    const dropped = e.dataTransfer.files[0];
    if (dropped) setFile(dropped);
  }, []);

  const handleUpload = async () => {
    if (!file) return;
    setStatus("uploading");
    setProgress(10);
    setError(null);

    try {
      const formData = new FormData();
      formData.append("file", file);

      setProgress(30);
      setStatus("processing");

      // Auth token is required — pipeline endpoints use Depends(verify_token)
      const token = typeof window !== "undefined" ? localStorage.getItem("token") : null;
      const headers: Record<string, string> = {};
      if (token) headers["Authorization"] = `Bearer ${token}`;

      // Prepend _BASE_PATH so the request routes through nginx → Next.js rewrites → FastAPI
      // Use hyphens in URL to match FastAPI router prefix (module_key uses underscores internally)
      const res = await fetch(`${_BASE_PATH}/api/{{ module_key | replace('_', '-') }}/upload`, {
        method: "POST",
        headers,
        body: formData,
      });

      setProgress(90);

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.detail || "Processing failed");
      }

      const data: ProcessingResult = await res.json();
      setResult(data);
      setStatus("completed");
      setProgress(100);
    } catch (err) {
      setError(err instanceof Error ? err.message : "Unknown error");
      setStatus("error");
    }
  };

  return (
    <div className="container mx-auto max-w-2xl py-8 space-y-6">
      <Card>
        <CardHeader>
          <CardTitle className="flex items-center gap-2">
            <Upload className="h-5 w-5" />
            {{ screen_title or display_name or (entity_slug | replace('_', ' ') | title) }}
          </CardTitle>
          <CardDescription>
            {{ screen_description or ('Process and analyse ' + (display_name or entity_slug | replace('_', ' '))) }}
          </CardDescription>
        </CardHeader>
        <CardContent>
          {status === "idle" && (
            <div
              onDrop={handleDrop}
              onDragOver={(e) => e.preventDefault()}
              className="border-2 border-dashed rounded-lg p-12 text-center cursor-pointer hover:border-primary transition-colors"
              onClick={() => document.getElementById("file-input")?.click()}
            >
              <FileText className="h-12 w-12 mx-auto mb-4 text-muted-foreground" />
              <p className="text-lg font-medium">Drop your document here</p>
              <p className="text-sm text-muted-foreground mt-1">
                Supports PDF, scanned documents, and images
              </p>
              <input
                id="file-input"
                type="file"
                className="hidden"
                accept=".pdf,.png,.jpg,.jpeg,.tiff"
                onChange={(e) => setFile(e.target.files?.[0] || null)}
              />
              {file && (
                <p className="mt-4 text-sm font-medium text-primary">
                  Selected: {file.name} ({(file.size / 1024).toFixed(0)} KB)
                </p>
              )}
            </div>
          )}

          {(status === "uploading" || status === "processing") && (
            <div className="space-y-4 py-8 text-center">
              <Loader2 className="h-12 w-12 mx-auto animate-spin text-primary" />
              <p className="text-lg font-medium">
                {status === "uploading" ? "Uploading..." : "Processing with AI..."}
              </p>
              <p className="text-sm text-muted-foreground">
                This usually takes less than a minute
              </p>
              <Progress value={progress} className="w-full" />
            </div>
          )}

          {status === "completed" && result && (
            <div className="space-y-4 py-4">
              <div className="text-center">
                <CheckCircle className="h-12 w-12 mx-auto mb-3 text-green-500" />
                <p className="text-lg font-medium">Processing Complete</p>
                <p className="text-sm text-muted-foreground">
                  Processed in {result.processing_time_seconds.toFixed(1)}s
                </p>
              </div>
              {/* Quality metrics */}
              {result.quality_metrics && Object.keys(result.quality_metrics).length > 0 && (
                <div className="grid grid-cols-2 gap-3 mt-4">
                  {Object.entries(result.quality_metrics).map(([key, val]) => (
                    <div key={key} className="rounded-lg border p-3 text-center">
                      <p className="text-xl font-bold">{typeof val === "number" ? `${(val * 100).toFixed(0)}%` : String(val)}</p>
                      <p className="text-xs text-muted-foreground">{key.replace(/_/g, " ")}</p>
                    </div>
                  ))}
                </div>
              )}
              {/* Steps completed */}
              {Array.isArray((result.data as any)?.steps_completed) && (
                <div className="flex flex-wrap gap-2 pt-2">
                  {((result.data as any).steps_completed as string[]).map((step, i) => (
                    <Badge key={i} variant="outline" className="flex items-center gap-1">
                      <CheckCircle className="h-3 w-3 text-green-500" />
                      {step.replace(/_/g, " ")}
                    </Badge>
                  ))}
                </div>
              )}
              {/* Raw output summary */}
              {result.data && Object.keys(result.data).length > 0 && !(result.data as any).steps_completed && (
                <div className="rounded-lg bg-muted p-4 text-sm font-mono overflow-auto max-h-48">
                  {JSON.stringify(result.data, null, 2)}
                </div>
              )}
              <div className="flex gap-2 pt-2">
                <Button variant="outline" onClick={() => { setStatus("idle"); setFile(null); setResult(null); }}>
                  Process Another
                </Button>
                <Button variant="outline" size="sm">
                  <Download className="h-4 w-4 mr-1" /> Export Result
                </Button>
              </div>
            </div>
          )}

          {status === "error" && (
            <div className="space-y-4 py-8 text-center">
              <AlertCircle className="h-12 w-12 mx-auto text-destructive" />
              <p className="text-lg font-medium">Processing Failed</p>
              <p className="text-sm text-destructive">{error}</p>
              <Button variant="outline" onClick={() => { setStatus("idle"); setError(null); }}>
                Try Again
              </Button>
            </div>
          )}

          {status === "idle" && file && (
            <Button className="w-full mt-4" onClick={handleUpload}>
              <Upload className="h-4 w-4 mr-2" />
              Upload and Process
            </Button>
          )}
        </CardContent>
      </Card>
    </div>
  );
}
