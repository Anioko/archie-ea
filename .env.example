# Copy to .env and set real values. NEVER commit .env.
FLASK_ENV=development
SECRET_KEY=change-me-generate-a-long-random-string
DATABASE_URL=postgresql://archie:archie@localhost:5432/archie

# First admin user (created by create_admin.py)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Optional: AI design assistant (leave blank to disable)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Abacus / Avolution portfolio connector (configured in-app under Admin)
# ABACUS_BASE_URL=https://abacus.example.com
