# Copy to .env and set real values. NEVER commit .env.
# NOTE: the app selects its config from FLASK_CONFIG (development|production|testing),
# NOT the standard FLASK_ENV. Setting FLASK_ENV has no effect.
FLASK_CONFIG=development
SECRET_KEY=change-me-generate-a-long-random-string
# PostgreSQL is required. Create the database first: createdb archie
# (uses the local 'postgres' superuser; adjust user/password/host as needed).
# Windows installs often run Postgres on 5439 — change the port below if so.
# For AI/embedding features, enable the pgvector extension:
#   CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/archie

# First admin user (created by create_admin.py)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Optional: AI design assistant (leave blank to disable)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Abacus / Avolution portfolio connector (configured in-app under Admin)
# ABACUS_BASE_URL=https://abacus.example.com
